---
import SimpleContactForm from "./SimpleContactForm.astro";
---

<section id="contact" class="py-12 md:py-24 lg:py-32 bg-muted/50">
  <div class="container px-4 md:px-6">
    <div class="flex flex-col items-center justify-center space-y-4 text-center">
      <div class="space-y-2">
        <h2 class="text-3xl font-bold tracking-tighter md:text-4xl">
          Get in <span class="bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent">Touch</span>
        </h2>
        <p class="mx-auto max-w-[700px] text-muted-foreground md:text-lg">
          Have questions? Ready to transform your mindset? Fill out the form below and we'll get back to you shortly.
        </p>
      </div>
    </div>

    <div class="mx-auto max-w-lg mt-8">
      <SimpleContactForm />
    </div>
  </div>
</section>