---
import { buttonVariants } from "@/components/ui/button";
---

<form id="contact" class="grid gap-4 max-w-lg mx-auto" data-form-type="contact">
  <div>
    <label for="name" class="block text-sm font-medium mb-1">
      Name
    </label>
    <input
      type="text"
      id="name"
      name="name"
      required
      class="w-full px-3 py-2 bg-muted/50 border border-primary/10 rounded-md focus:outline-none focus:ring-2 focus:ring-primary/50"
      placeholder="Your name"
    />
  </div>

  <div>
    <label for="email" class="block text-sm font-medium mb-1">
      Email
    </label>
    <input
      type="email"
      id="email"
      name="email"
      required
      class="w-full px-3 py-2 bg-muted/50 border border-primary/10 rounded-md focus:outline-none focus:ring-2 focus:ring-primary/50"
      placeholder="your.email@example.com"
    />
  </div>

  <div>
    <label for="message" class="block text-sm font-medium mb-1">
      Message
    </label>
    <textarea
      id="message"
      name="message"
      required
      rows={4}
      class="w-full px-3 py-2 bg-muted/50 border border-primary/10 rounded-md focus:outline-none focus:ring-2 focus:ring-primary/50"
      placeholder="How can we help you with positive thinking?"
    ></textarea>
  </div>

  <input name="form_name" type="hidden" value="Positive Thinking Inquiry" />
  
  <button 
    type="submit"
    class={buttonVariants({ className: "w-full" })}
  >
    Send Message
  </button>
</form>