<section id="services" class="py-12 md:py-24 lg:py-32 bg-muted/50">
  <div class="container px-4 md:px-6">
    <div class="flex flex-col items-center justify-center space-y-4 text-center">
      <div class="space-y-2">
        <h2 class="text-3xl font-bold tracking-tighter md:text-4xl">
          Our <span class="bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent">Services</span>
        </h2>
        <p class="mx-auto max-w-[700px] text-muted-foreground md:text-lg">
          We offer comprehensive services designed to help you cultivate a positive mindset
          and transform every aspect of your life.
        </p>
      </div>
    </div>
    
    <div class="mx-auto grid max-w-5xl grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3 mt-12">
      <div class="flex flex-col justify-between rounded-lg border bg-card p-6 shadow-sm">
        <div>
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary mb-3"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
          <h3 class="text-lg font-bold">Mindset Coaching</h3>
          <p class="text-muted-foreground text-sm mt-2">
            One-on-one sessions with certified positive thinking coaches to rewire thought patterns.
          </p>
        </div>
        <div class="mt-4 h-1 w-12 bg-gradient-to-r from-primary to-secondary rounded-full"></div>
      </div>

      <div class="flex flex-col justify-between rounded-lg border bg-card p-6 shadow-sm">
        <div>
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary mb-3"><path d="M4.9 19.1C1 15.2 1 8.8 4.9 4.9"/><path d="M7.8 16.2c-2.3-2.3-2.3-6.1 0-8.5"/><path d="M14 3a2 2 0 0 1 2 2v5.5a2.5 2.5 0 0 1 5 0V12a9 9 0 0 1-9 9h0a9 9 0 0 1-9-9v-1.5a2.5 2.5 0 0 1 5 0V9a2 2 0 0 1 2-2h0a2 2 0 0 1 2 2v2.5"/></svg>
          <h3 class="text-lg font-bold">Wellness Programs</h3>
          <p class="text-muted-foreground text-sm mt-2">
            Holistic approaches to mental and emotional wellbeing through positive practices.
          </p>
        </div>
        <div class="mt-4 h-1 w-12 bg-gradient-to-r from-primary to-secondary rounded-full"></div>
      </div>

      <div class="flex flex-col justify-between rounded-lg border bg-card p-6 shadow-sm">
        <div>
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary mb-3"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          <h3 class="text-lg font-bold">Community Support</h3>
          <p class="text-muted-foreground text-sm mt-2">
            Join our community of positive thinkers for encouragement, accountability, and friendship.
          </p>
        </div>
        <div class="mt-4 h-1 w-12 bg-gradient-to-r from-primary to-secondary rounded-full"></div>
      </div>
    </div>
  </div>
</section>