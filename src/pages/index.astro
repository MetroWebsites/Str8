---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/Navbar";
import Hero from "@/components/Hero";
import Features from "@/components/Features";
import About from "@/components/About";
import Testimonials from "@/components/Testimonials";
import CallToAction from "@/components/CallToAction";
import ContactForm from "@/components/ContactForm";
---

<BaseLayout
  title="Str8PositiveThinking - Transform Your Life With Positive Thinking"
  description="Discover the power of positive thinking and transform your life with our proven techniques, coaching, and community support."
>
  <Navbar slot="header" client:load />
  <Hero client:load />
  <Features client:load />
  <About client:load />
  <Testimonials client:load />
  <CallToAction client:load />
  <ContactForm client:load />
</BaseLayout>