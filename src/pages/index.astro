        align-items: center;
        gap: 2rem;
        z-index: 1001;
        transform: translateY(-100%);
        transition: all 0.5s ease;
      }
      
      .mobile-menu.open {
        transform: translateY(0);
      }
      
      .mobile-menu a {
        color: var(--text-primary);
        text-decoration: none;
        font-size: 1.5rem;
        font-weight: 600;
        transition: all 0.3s ease;
      }
      
      .mobile-menu a:hover {
        color: var(--accent-gold);
      }
      
      .close-menu-btn {
        position: absolute;
        top: 2rem;
        right: 2rem;
        background: none;
        border: none;
        color: var(--text-primary);
        font-size: 1.5rem;
        cursor: pointer;
      }
      
