---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="Str8Positive - Positive Thinking Website"
  description="Transform your life with positive thinking"
>
  <header class="py-4 border-b">
    <div class="container mx-auto px-4">
      <div class="flex justify-between items-center">
        <a href="/" class="font-bold text-xl">Str8Positive</a>
        <nav class="hidden md:flex gap-6">
          <a href="#about">About</a>
          <a href="#services">Services</a>
          <a href="#contact">Contact</a>
        </nav>
      </div>
    </div>
  </header>

  <section class="py-12">
    <div class="container mx-auto px-4 text-center">
      <h1 class="text-4xl font-bold mb-6">Transform Your Life With Positive Thinking</h1>
      <p class="mb-8 max-w-2xl mx-auto">
        Discover the power of positive thinking and transform your life with our proven techniques.
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href="#contact" class="bg-blue-500 hover:bg-blue-600 text-white px-6 py-2 rounded">
          Get Started
        </a>
        <a href="#about" class="border border-gray-300 px-6 py-2 rounded">
          Learn More
        </a>
      </div>
    </div>
  </section>

  <section id="services" class="py-12 bg-gray-50">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold mb-6 text-center">Our Services</h2>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-white p-6 rounded shadow">
          <h3 class="font-bold text-xl mb-2">Mindset Coaching</h3>
          <p>One-on-one sessions with certified positive thinking coaches.</p>
        </div>
        <div class="bg-white p-6 rounded shadow">
          <h3 class="font-bold text-xl mb-2">Wellness Programs</h3>
          <p>Holistic approaches to mental and emotional wellbeing.</p>
        </div>
        <div class="bg-white p-6 rounded shadow">
          <h3 class="font-bold text-xl mb-2">Community Support</h3>
          <p>Join our community of positive thinkers for encouragement and friendship.</p>
        </div>
      </div>
    </div>
  </section>

  <section id="about" class="py-12">
    <div class="container mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-8">
        <div>
          <h2 class="text-3xl font-bold mb-6">About Str8Positive</h2>
          <p class="mb-4">
            Str8Positive was founded with a simple mission: to help people transform their lives
            through the power of positive thinking.
          </p>
          <ul class="space-y-2">
            <li>Transform negative thinking into positive energy</li>
            <li>Develop resilience and mental strength</li>
            <li>Create a personalized positive thinking practice</li>
          </ul>
        </div>
        <div class="bg-gray-50 p-6 rounded">
          <div class="text-center">
            <h3 class="text-xl font-bold mb-2">Our Mission</h3>
            <p class="mb-6">
              To empower individuals to transform their mindset and achieve their fullest potential
              through proven positive thinking techniques.
            </p>
            <div class="grid grid-cols-3 gap-4">
              <div class="bg-white p-4 rounded">
                <div class="text-2xl font-bold">10k+</div>
                <div class="text-sm text-gray-500">Students</div>
              </div>
              <div class="bg-white p-4 rounded">
                <div class="text-2xl font-bold">24</div>
                <div class="text-sm text-gray-500">Coaches</div>
              </div>
              <div class="bg-white p-4 rounded">
                <div class="text-2xl font-bold">8</div>
                <div class="text-sm text-gray-500">Years</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="contact" class="py-12 bg-gray-50">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold mb-6 text-center">Get in Touch</h2>
      <div class="max-w-lg mx-auto">
        <form class="bg-white p-6 rounded shadow space-y-4">
          <div>
            <label for="name" class="block mb-1 font-medium">Name</label>
            <input
              type="text"
              id="name"
              name="name"
              class="w-full p-2 border rounded"
              required
            />
          </div>
          <div>
            <label for="email" class="block mb-1 font-medium">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              class="w-full p-2 border rounded"
              required
            />
          </div>
          <div>
            <label for="message" class="block mb-1 font-medium">Message</label>
            <textarea
              id="message"
              name="message"
              rows="4"
              class="w-full p-2 border rounded"
              required
            ></textarea>
          </div>
          <input type="hidden" name="form_name" value="Contact Form" />
          <button
            type="submit"
            class="w-full bg-blue-500 hover:bg-blue-600 text-white py-2 px-4 rounded"
          >
            Send Message
          </button>
        </form>
      </div>
    </div>
  </section>

  <footer class="py-6 border-t">
    <div class="container mx-auto px-4 text-center">
      <p class="mb-4">&copy; {new Date().getFullYear()} Str8Positive. All rights reserved.</p>
      <p class="text-sm text-gray-500">
        Built with
        <a href="https://new.website" target="_blank" rel="noreferrer" class="text-blue-500">
          new.website
        </a>
      </p>
    </div>
  </footer>
</BaseLayout>