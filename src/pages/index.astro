---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navigation from "@/components/Navigation";
import HeroSection from "@/components/HeroSection";
import FeatureSection from "@/components/FeatureSection";
import AboutSection from "@/components/AboutSection";
import TestimonialSection from "@/components/TestimonialSection";
import CtaSection from "@/components/CtaSection";
import ContactSection from "@/components/ContactSection";
import Footer from "@/components/Footer";
---

<BaseLayout
  title="Str8Positive - Transform Your Life Through Positive Thinking"
  description="Discover the power of positive thinking and transform your life with our proven techniques, coaching, and supportive community."
>
  <div class="min-h-screen flex flex-col">
    <Navigation client:load />
    <main class="flex-grow mt-16">
      <HeroSection client:load />
      <FeatureSection client:load />
      <AboutSection client:load />
      <TestimonialSection client:load />
      <CtaSection client:load />
      <ContactSection client:load />
    </main>
    <Footer client:load />
  </div>
</BaseLayout>